# =========================
# App
# =========================
ENV=development
PORT=8000
# 画像アップロード先（未指定時は環境に応じて自動判定）
# ローカル例: ../infra/uploads
# コンテナ例: /app/uploads
#UPLOAD_DIR=../infra/uploads

# =========================
# Database
# =========================
DATABASE_URL=postgresql://user:password@localhost:5432/climo_db

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=your_openai_api_key

# =========================
# JWT (認証やるなら)
# =========================
SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# External API（天気など）
# =========================
# OpenWeatherMap API キーの取得方法:
# 1. https://openweathermap.org/api にアクセスし、アカウントを作成
# 2. ダッシュボードから「API keys」タブを開き、デフォルトキーをコピー
# 3. 下記の値に貼り付けて保存
OPENWEATHER_API_KEY=your_openweather_api_key

# =========================
# Firebase
# =========================
# Firebase Admin SDK サービスアカウントキーのパス
FIREBASE_CONFIG_PATH=app/config/serviceAccountKey.json
# Firebase Web API キー（Identity Toolkit REST API 用）
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# =========================
# 開発環境認証バイパス
# =========================
# APP_ENV=development のときに Firebase 認証をスキップする場合は true に設定
# 本番環境では必ず false または未設定にすること
ALLOW_DEV_AUTH_BYPASS=false
DEV_USER_UID=dev-user
DEV_USER_EMAIL=dev@example.com