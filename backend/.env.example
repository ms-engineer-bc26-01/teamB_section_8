# =========================
# App
# =========================
ENV=development
PORT=8000

# =========================
# Database
# =========================
DATABASE_URL=postgresql://user:password@localhost:5432/climo_db

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=your_openai_api_key

# =========================
# JWT (認証やるなら)
# =========================
SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# External API（天気など）
# =========================
WEATHER_API_KEY=your_weather_api_key