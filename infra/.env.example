# 環境変数サンプルファイル
# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.example .env

# OpenWeatherMap API キー
OPENWEATHER_API_KEY=your_openweather_api_key_here

# OpenAI API キー
OPENAI_API_KEY=your_openai_api_key_here

# アプリ実行環境 (development / production)
APP_ENV=development

# Firebase Web API キー
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# 開発用認証バイパス設定（本番環境では必ず false にすること）
ALLOW_DEV_AUTH_BYPASS=false
DEV_USER_UID=dev-user
DEV_USER_EMAIL=dev@example.com
